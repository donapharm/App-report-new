# ==== App Report New — biến môi trường mẫu ====
# KHÔNG commit file .env thật lên GitHub.

# Cổng backend API
PORT=3873
HOST=127.0.0.1
CORS_ORIGINS=https://report.donapharm.asia,https://reportnew.donapharm.asia,https://home.donapharm.asia

# --- LIVE integration (để trống khi chạy demo bằng dữ liệu mẫu) ---
# Đăng nhập nội bộ
OTP_BACKEND_URL=http://127.0.0.1:3848
SSO_VERIFY_URL=http://127.0.0.1:3862/api/sso/verify

# Nguồn doanh thu ORDS/Lumos (fallback khi kỳ chưa có upload). Để TRỐNG = tắt ORDS.
ORDS_SQL_API=
# ORDS_SQL_API=https://ceo.donapharm.one/ords/donapharm_new/sql-api/run
ORDS_AUTH=        # ví dụ "Basic xxx" hoặc "Bearer xxx" nếu ORDS yêu cầu xác thực

# Khóa ký session (đổi thành chuỗi ngẫu nhiên khi lên production)
SESSION_SECRET=change-me-in-production

# --- Đăng nhập TELEGRAM (SPEC_LOGIN_V2) ---
# Bí mật DÙNG CHUNG giữa backend app và telegram-bot worker (KHÔNG commit .env thật).
TELEGRAM_BOT_SECRET=
# Bot RIÊNG qua @BotFather (KHÔNG dùng chung token với bot OpenClaw). Chỉ worker cần token.
TELEGRAM_BOT_TOKEN=
# Username bot (không kèm @) để dựng link t.me/<bot>?start=RP-... trên màn đăng nhập.
TELEGRAM_BOT_USERNAME=
# URL backend cho worker gọi confirm (mặc định http://localhost:${PORT}).
# APP_BASE_URL=http://localhost:3873
# APP_PUBLIC_URL=https://report.donapharm.asia

# Bật chế độ dữ liệu mẫu (1 = dùng data/ ẩn danh, 0 = nối nguồn thật)
USE_SAMPLE_DATA=1

# Đăng nhập DEMO (bấm chọn tài khoản, không mật khẩu). 1 = bật (demo), 0 = KHOÁ.
# ⚠ Khi dữ liệu đã THẬT và có OTP/SSO -> đặt =0 để tránh lộ dữ liệu.
ALLOW_DEMO_LOGIN=1

# --- AI hỏi nhanh (LLM diễn giải, grounded) ---
# Để TRỐNG = AI chạy code-first (không gọi LLM). Điền key để bật LLM diễn giải.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001   # rẻ/nhanh; đổi claude-sonnet-5 nếu cần sâu hơn

# Service token riêng cho DataHub gọi /api/targets (ưu tiên hash; token thật chỉ lưu ở DataHub secret/env)
APP_REPORT_SERVICE_TOKEN_SHA256=
# APP_REPORT_SERVICE_TOKEN= # fallback dev only; production nên dùng SHA256 ở trên
